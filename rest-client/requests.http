@baseURL = http://localhost:3000
@jwtToken={{{{logInUser.response.body.accessToken}}}}


### authLogin
# @name logInUser
POST {{baseURL}}/auth/login
Content-Type: application/json

{
  "email": "teste@teste.com",
  "password": "123456"
}

### get an user
# @name ReadOneUser
GET {{baseURL}}/user/1234

### create an user
# @name createUser
POST {{baseURL}}/user
Content-Type: application/json

{
  "email": "teste@teste.com",
  "password": "123456",
  "name":"teste da silva"
}
